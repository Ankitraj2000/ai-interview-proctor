# ============================================================
# AI Interview Proctor System — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── MySQL Database ───────────────────────────────────────────
MYSQL_DATABASE=proctor_db
MYSQL_ROOT_PASSWORD=your_strong_db_password_here
MYSQL_USER=root

# ── JWT Token Signing ────────────────────────────────────────
# Must be a base64-encoded string of at least 256 bits (32 chars).
# Generate with: openssl rand -base64 64
JWT_SECRET=YW50aWdyYXZpdHlwcm9jdG9yc3lzdGVtc2VjcmV0a2V5Zm9ycHJvZHVjdGlvbnNlY3VyaXR5dG9rZW5nZW5lcmF0aW9u

# ── SMTP Email (Optional — OTPs are logged to console if unset) ──
SMTP_USERNAME=your_email@gmail.com
# For Gmail: use an App Password (not your main password)
SMTP_PASSWORD=your_gmail_app_password
